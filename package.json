{
  "name": "ark",
  "description": "Noé's Ark for the offline age: an offline-first survival computer for mobile.",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "packageManager": "bun@1.3.3",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rodrgds/ark.git"
  },
  "bugs": {
    "url": "https://github.com/rodrgds/ark/issues"
  },
  "homepage": "https://ark.rgo.pt",
  "keywords": [
    "offline-first",
    "survival",
    "react-native",
    "expo",
    "maps",
    "local-ai",
    "rag",
    "sqlite"
  ],
  "scripts": {
    "dev": "expo start -c",
    "android": "expo start -c --android",
    "ios": "expo start -c --ios",
    "ios:dev": "expo run:ios",
    "web": "expo start -c --web",
    "typecheck": "bun run typecheck:app && bun run typecheck:tests",
    "typecheck:app": "tsc --noEmit",
    "typecheck:tests": "tsc --noEmit -p tsconfig.tests.json",
    "format:check": "prettier --check .",
    "lint": "eslint . --quiet",
    "check": "bun run typecheck && bun run lint && bun run test",
    "test": "bun test ././app/*.test.ts ././app/**/*.test.ts ././src/**/*.test.ts ././modules/**/*.test.ts && bun test ./src/services/preferences/tab-preferences.service.rntl.ts --timeout 12000 && bun test ./src/components/ui/input.rntl.tsx --timeout 12000 && bun test ./src/components/settings/tab-preferences-card.rntl.tsx --timeout 12000 && bun test ./src/components/settings/diagnostics-card.rntl.tsx --timeout 12000 && bun test ./src/components/settings/security-section.rntl.tsx --timeout 12000 && bun test ./src/components/settings/ai-section.rntl.tsx --timeout 12000 && bun test ./src/components/settings/downloads-card.rntl.tsx --timeout 12000 && bun test ./src/components/layout/function-search.rntl.tsx --timeout 12000 && bun test ./src/test/chat-index-screen.rntl.tsx --timeout 12000 && bun test ./src/test/tabs-layout.rntl.tsx --timeout 12000 && bun test ./src/test/note-editor-autosave.rntl.tsx --timeout 12000 && bun test ./src/test/document-reader.rntl.tsx --timeout 12000 && bun test ./src/test/content-reader.rntl.tsx --timeout 12000 && bun test ./src/test/library-screen.rntl.tsx --timeout 12000 && bun test ./src/test/map-screen.rntl.tsx --timeout 12000",
    "maps:catalog:build": "node scripts/build-map-catalog.mjs",
    "check:docs": "node scripts/check-docs-drift.mjs",
    "build-or-docs": "bun run check:docs && bun run docs:build",
    "verify": "bun run format:check && bun run check && bun run build-or-docs",
    "docs:dev": "vitepress dev docs --host 127.0.0.1",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs --host 127.0.0.1",
    "docs:deploy": "bun run docs:build && wrangler pages deploy docs/.vitepress/dist --project-name=ark-docs",
    "clean": "rm -rf .expo node_modules",
    "android:build:dev": "expo prebuild --platform android --no-install --no-clean && cd android && ./gradlew assembleDebug",
    "android:build:prod": "expo prebuild --platform android --no-install --no-clean && cd android && ./gradlew assembleRelease",
    "android:release:apks": "bash scripts/android-release-apks.sh",
    "ios:build:sim": "bash scripts/ios-simulator-build.sh",
    "build-send": "node scripts/build-send.mjs",
    "build-send:dev": "node scripts/build-send.mjs --dev",
    "android:install": "adb install android/app/build/outputs/apk/debug/app-debug.apk",
    "doctor": "npx react-doctor@latest"
  },
  "dependencies": {
    "@10play/tentap-editor": "1.0.1",
    "@azure/core-asynciterator-polyfill": "^1.0.2",
    "@maplibre/maplibre-react-native": "^11.2.1",
    "@noble/ciphers": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "@react-native-ai/llama": "^0.12.0",
    "@react-native-community/netinfo": "12.0.1",
    "@rn-primitives/portal": "~1.4.0",
    "@rn-primitives/slot": "^1.4.0",
    "@shopify/react-native-skia": "2.6.2",
    "@stardazed/streams-text-encoding": "^1.0.2",
    "@swmansion/react-native-bottom-sheet": "^0.12.0",
    "@ungap/structured-clone": "^1.3.1",
    "ai": "^6.0.191",
    "ark-ocr": "./modules/ark-ocr",
    "ark-routing": "./modules/ark-routing",
    "ark-system-colors": "./modules/ark-system-colors",
    "ark-zim": "./modules/ark-zim",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.2.1",
    "defuddle": "^0.18.1",
    "expo": "~57.0.4",
    "expo-asset": "~57.0.3",
    "expo-audio": "~57.0.0",
    "expo-build-properties": "~57.0.3",
    "expo-constants": "~57.0.3",
    "expo-crypto": "~57.0.0",
    "expo-document-picker": "~57.0.0",
    "expo-file-system": "~57.0.0",
    "expo-haptics": "~57.0.0",
    "expo-image": "~57.0.0",
    "expo-image-picker": "~57.0.2",
    "expo-linking": "~57.0.2",
    "expo-local-authentication": "~57.0.0",
    "expo-localization": "~57.0.0",
    "expo-location": "~57.0.2",
    "expo-notifications": "~57.0.3",
    "expo-print": "~57.0.0",
    "expo-router": "~57.0.4",
    "expo-secure-store": "~57.0.0",
    "expo-sensors": "~57.0.1",
    "expo-sharing": "~57.0.3",
    "expo-splash-screen": "~57.0.2",
    "expo-sqlite": "~57.0.0",
    "expo-status-bar": "~57.0.0",
    "expo-task-manager": "~57.0.2",
    "fast-xml-parser": "^5.8.0",
    "fflate": "^0.8.3",
    "linkedom": "^0.18.12",
    "llama.rn": "^0.12.3",
    "lucide-react-native": "^0.545.0",
    "marked": "^18.0.5",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-audio-api": "^0.12.2",
    "react-native-blob-util": "^0.24.9",
    "react-native-enriched-markdown": "^0.6.0",
    "react-native-executorch": "^0.9.0",
    "react-native-executorch-expo-resource-fetcher": "^0.9.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-keyboard-controller": "1.21.9",
    "react-native-pdf": "^7.0.4",
    "react-native-rag": "^0.9.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.16.1",
    "react-native-worklets": "0.10.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "uniwind": "1.6.3",
    "victory-native": "41.26.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@expo/ngrok": "^4.1.0",
    "@react-native-community/cli": "^20.1.3",
    "@testing-library/react-native": "14.0.0",
    "@types/bun": "^1.3.14",
    "@types/node": "^26.1.1",
    "@types/react": "~19.2.10",
    "eslint": "^9",
    "eslint-config-expo": "~57.0.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "~6.0.3",
    "vitepress": "^1.6.4",
    "wrangler": "^4.107.0"
  },
  "trustedDependencies": [
    "@shopify/react-native-skia",
    "llama.rn",
    "unrs-resolver"
  ],
  "overrides": {
    "react-dom": "19.2.3"
  },
  "expo": {
    "install": {
      "exclude": [
        "react-native-worklets"
      ]
    },
    "autolinking": {
      "nativeModulesDir": "./config/empty-native-modules"
    }
  },
  "private": false,
  "patchedDependencies": {
    "@10play/tentap-editor@1.0.1": "patches/@10play%2Ftentap-editor@1.0.1.patch",
    "uniwind@1.6.3": "patches/uniwind@1.6.3.patch"
  }
}
