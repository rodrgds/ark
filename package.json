{
  "name": "ark",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "dev": "expo start -c",
    "android": "expo start -c --android",
    "ios": "expo start -c --ios",
    "web": "expo start -c --web",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --quiet",
    "check": "bun run typecheck && bun run lint && bun test",
    "test": "bun test",
    "maps:catalog:build": "node scripts/build-map-catalog.mjs",
    "clean": "rm -rf .expo node_modules",
    "android:build:dev": "expo prebuild --platform android --no-install && cd android && ./gradlew assembleDebug",
    "android:build:prod": "expo prebuild --platform android --no-install && cd android && ./gradlew assembleRelease",
    "android:install": "adb install android/app/build/outputs/apk/debug/app-debug.apk"
  },
